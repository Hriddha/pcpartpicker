Options -MultiViews

RewriteEngine On

# Allow OPTIONS preflight requests through to PHP
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [QSA,L]

# Handle Authorization header
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Set allowed origin based on request origin
SetEnvIf Origin "^https://pcpartpicker-eight\.vercel\.app$" ALLOWED_ORIGIN=$0
SetEnvIf Origin "^http://localhost:3000$" ALLOWED_ORIGIN=$0

<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Max-Age "86400"
    Header always set Access-Control-Allow-Origin "%{ALLOWED_ORIGIN}e" env=ALLOWED_ORIGIN
</IfModule>
